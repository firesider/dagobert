# Vorlage fuer lokale Umgebungsvariablen.
# 1. Kopiere diese Datei nach `.env`:
#       cp .env.example .env
# 2. Trage echte Werte ein.
# 3. Lade vor CLI-Aufrufen einmal pro Shell:
#       set -a; source .env; set +a
# `.env` ist via `.gitignore` ausgeschlossen und darf NICHT eingecheckt werden.

# --- Alpaca ---
# Paper-Keys aus https://app.alpaca.markets/  (Paper-Modus oben links umschalten)
ALPACA_API_KEY_ID=PK_dein_paper_key_id
ALPACA_API_SECRET_KEY=dein_paper_secret
ALPACA_PAPER=true
# iex = kostenlos, sip = kostenpflichtig (Algo Trader Plus)
ALPACA_DATA_FEED=iex
